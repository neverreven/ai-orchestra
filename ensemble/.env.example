# ============================================================
# AI Orchestra Ensemble — root .env
# Copy to .env and fill in your values.
# Per-project values live in ensemble/projects/<role>/.env
# ============================================================

# Anthropic API key (required for all agent operations)
ANTHROPIC_API_KEY=

# OpenAI API key (optional — used if model routing selects GPT)
OPENAI_API_KEY=

# Telegram owner user ID (get from @userinfobot in Telegram)
# Only this user can issue /restart, /status, /allow, /revoke
OWNER_TELEGRAM_ID=

# Log level: debug | info | warn | error
LOG_LEVEL=info

# ── GitHub integration (optional) ────────────────────────────────────────────
# See: core/skills/setup/setup-github/SKILL.md
# Requires: bun add @octokit/rest

# Personal Access Token with repo + pull_requests + checks scopes
GITHUB_TOKEN=

# Secret set when creating the webhook on github.com/settings/hooks
# Must be set to validate incoming webhook payloads
GITHUB_WEBHOOK_SECRET=

# Set to true to post named check runs on PRs (requires checks scope on PAT)
GITHUB_CHECK_RUN=false

# ── Slack channel (optional — alternative / complement to Telegram) ──────────
# Requires: bun add @slack/bolt
# See: core/skills/setup/setup-slack/SKILL.md

# Set to false to disable even when tokens are present
ENABLE_SLACK=true

# Bot User OAuth Token from your Slack App (xoxb-...)
SLACK_BOT_TOKEN=

# App-Level Token with connections:write scope (xapp-...)
SLACK_APP_TOKEN=

# Slack User ID of the owner — find via Profile > ⋮ > Copy member ID (e.g. U0123456789)
OWNER_SLACK_USER_ID=

# ── Telegram (optional — set ENABLE_TELEGRAM=false to disable) ───────────────
# Telegram is enabled by default when TELEGRAM_BOT_TOKEN is present.

# Set to false to disable Telegram even when token is present
ENABLE_TELEGRAM=true

# ── Local Web Chat UI (Tier 2 communication without Telegram) ────────────────
# Set ENABLE_WEB_UI=true to start the web chat server when the Lead agent runs.
# Access it at http://localhost:WEB_UI_PORT in any browser on this machine.
# Use `npx @neverreven/ai-orchestra chat` to open it automatically.

# Enable local web chat UI (default: false)
ENABLE_WEB_UI=false

# Port for the web chat server (default: 3847)
WEB_UI_PORT=3847

# Optional auth token — if set, the URL becomes http://localhost:PORT?token=TOKEN
# Leave blank for open access (safe on a private machine, not recommended on a server)
WEB_UI_TOKEN=
